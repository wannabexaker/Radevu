# Keep the Docker build context lean.
# Anything not needed inside the image stays out — faster builds, smaller layers,
# zero risk of leaking local secrets or stale build artifacts.

# Node / build artifacts
node_modules
**/node_modules
.pnpm-store
.next
**/.next
dist
**/dist
build
**/build
out
**/out
*.tsbuildinfo

# Env files — image uses runtime env from compose, never bake secrets in
.env
.env.*
!**/.env.example
infra/.env

# Tests / coverage / playwright
coverage
**/coverage
playwright-report
**/playwright-report
test-results
**/test-results

# VCS / IDE / OS
.git
.gitignore
.github
.vscode
.idea
*.swp
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Local docs and Claude / Codex orchestration (not needed at runtime)
.claude
.mcp.json
codex
docs

# Cloudflared local config (only example is part of the repo, real config is local)
infra/cloudflared/config.yml
infra/cloudflared/*.json

# Local data dirs that may exist on the dev machine
/srv
data
backups
