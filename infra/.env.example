# === GHCR (production compose only) ===
GHCR_USER=wannabexaker                            # GitHub user/org (image: ghcr.io/$GHCR_USER/radevu-web)
RADEVU_IMAGE_TAG=latest                           # override to a specific sha for pinned deploys

# === Database ===
POSTGRES_DB=radevu
POSTGRES_USER=radevu
POSTGRES_PASSWORD=                                # `openssl rand -base64 32`
DATABASE_URL=postgresql://radevu:CHANGEME@postgres:5432/radevu

# === Redis ===
REDIS_URL=redis://redis:6379

# === Auth ===
BETTER_AUTH_SECRET=                               # `openssl rand -hex 32`
BETTER_AUTH_URL=http://radevu.local:3000          # https://dashboard.radevu.gr in Beta Phase 1+

# === Email (Resend) ===
RESEND_API_KEY=                                   # leave blank in local dev until you have a real re_ key
RESEND_FROM_EMAIL=noreply@radevu.local            # noreply@radevu.gr in Beta Phase 1+
CONTACT_NOTIFICATION_EMAIL=                       # founder email for landing contact requests
BOOKING_OWNER_ALERT_EMAIL_OVERRIDE=               # optional sandbox/debug override; blank sends booking alerts to business contact email

# === Cloudflare Turnstile ===
# Anti-spam on register/password reset. Create a Managed widget for
# radevu.olamov.com in the Cloudflare dashboard.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# === Domain / routing ===
BOOKING_BASE_DOMAIN=radevu.local                  # radevu.gr in Beta Phase 1+
ROUTING_MODE=subpath                              # subdomain in Beta Phase 1+

# === Cloudflare Tunnel (Beta Phase 1+ only — leave blank in Phase 0) ===
CLOUDFLARE_TUNNEL_TOKEN=

# === Node ===
NODE_ENV=production

# === Demo seed credentials (Phase 0 only) ===
# Optional. If empty, the seed uses local defaults for demo logins.
# Set real values before showing owner dashboards outside your LAN.
SEED_DESPOINA_PASSWORD=
SEED_IOANNIS_PASSWORD=
