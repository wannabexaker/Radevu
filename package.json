{
  "name": "radevu",
  "version": "0.0.0",
  "private": true,
  "description": "Radevu — booking SaaS platform for small service businesses.",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @radevu/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @radevu/web test:e2e",
    "dev:infra": "docker compose -f infra/docker-compose.yml -f infra/docker-compose.dev-local.yml --env-file infra/.env up -d postgres redis",
    "db:generate": "pnpm --filter @radevu/db generate",
    "db:generate:local": "node scripts/db-local.mjs generate",
    "db:migrate": "pnpm --filter @radevu/db migrate:dev",
    "db:migrate:local": "node scripts/db-local.mjs migrate:deploy",
    "db:seed:local": "node scripts/db-local.mjs seed",
    "db:seed:e2e:local": "node scripts/db-local.mjs seed:e2e"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
